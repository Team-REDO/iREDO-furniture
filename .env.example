# ----------------------
# GENERAL
# ----------------------

ENVIRONMENT=development

# ----------------------
# API GATEWAY
# ----------------------

API_GATEWAY_PORT=8080

# ----------------------
# CLIENT
# ----------------------

CLIENT_PORT=3000
API_GATEWAY_URL=http://api-gateway:8080

# ----------------------
# DATABASES
# ----------------------

PRODUCT_WRITE_DB_HOST=product-write-db
PRODUCT_WRITE_DB_PORT=5432
PRODUCT_WRITE_DB_NAME=product_write
PRODUCT_WRITE_DB_USER=postgres
PRODUCT_WRITE_DB_PASSWORD=postgres

PRODUCT_READ_DB_HOST=product-read-db
PRODUCT_READ_DB_PORT=5432
PRODUCT_READ_DB_NAME=product_read
PRODUCT_READ_DB_USER=postgres
PRODUCT_READ_DB_PASSWORD=postgres

USER_DB_HOST=user-db
USER_DB_PORT=5432
USER_DB_NAME=user_db
USER_DB_USER=postgres
USER_DB_PASSWORD=postgres

PURCHASE_DB_HOST=purchase-db
PURCHASE_DB_PORT=5432
PURCHASE_DB_NAME=purchase_db
PURCHASE_DB_USER=postgres
PURCHASE_DB_PASSWORD=postgres

# ----------------------
# RABBITMQ
# ----------------------

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

PRODUCT_EVENTS_QUEUE=product-events
ORDER_EVENTS_QUEUE=order-events
EMAIL_QUEUE=email-events

# ----------------------
# OAUTH
# ----------------------

OAUTH_PROVIDER_URL=https://oauth-provider.example
OAUTH_CLIENT_ID=example-client-id
OAUTH_CLIENT_SECRET=example-secret

# ----------------------
# STRIPE
# ----------------------

STRIPE_API_KEY=sk_test_example
STRIPE_WEBHOOK_SECRET=whsec_example

# ----------------------
# FILE STORAGE / CDN
# ----------------------

FILE_STORAGE_URL=https://filestorage.example
CDN_URL=https://cdn.example

# ----------------------
# EMAIL SERVICE
# ----------------------

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer
SMTP_PASSWORD=password
SMTP_FROM=noreply@furniturestore.com